{
  "id": "ch01",
  "title": "항공권·온라인 체크인 확인",
  "summary": "출발 전 온라인 체크인, 좌석 선택, 수하물 규정 확인",
  "dialogues": [
    {
      "id": "ch01_d01",
      "title": "온라인 체크인 시작",
      "lines": [
        {
          "speaker": "나",
          "en": "Hi, I'd like to check in online for my flight.",
          "ko": "안녕하세요, 제 항공편 온라인 체크인을 하고 싶어요."
        },
        {
          "speaker": "직원",
          "en": "Sure. Can I have your booking reference?",
          "ko": "네. 예약 번호를 알려주시겠어요?"
        },
        {
          "speaker": "나",
          "en": "It's KX7 9P2.",
          "ko": "KX7 9P2입니다."
        },
        {
          "speaker": "직원",
          "en": "Great, you're all checked in.",
          "ko": "좋습니다, 체크인 완료되었습니다."
        }
      ],
      "keyExpressions": [
        {
          "en": "I'd like to check in online.",
          "ko": "온라인 체크인하고 싶어요. — 정중한 요청. 호텔에서 나갈 때 쓰는 check out과 혼동하지 마세요.",
          "alternatives": [
            {
              "en": "Can I check in online?",
              "ko": "온라인으로 체크인할 수 있나요?"
            },
            {
              "en": "I want to do online check-in.",
              "ko": "온라인 체크인을 하려고요."
            }
          ]
        },
        {
          "en": "booking reference",
          "ko": "예약 번호 (영문+숫자 코드). confirmation number라고도 합니다.",
          "alternatives": [
            {
              "en": "confirmation number",
              "ko": "예약 확인 번호"
            },
            {
              "en": "reservation code",
              "ko": "예약 코드"
            }
          ]
        },
        {
          "en": "You're all checked in.",
          "ko": "체크인 다 됐습니다. — 직원이 완료를 알릴 때 쓰는 표현.",
          "alternatives": [
            {
              "en": "Your check-in is complete.",
              "ko": "체크인이 완료되었습니다."
            },
            {
              "en": "You're good to go.",
              "ko": "다 되셨어요. (가셔도 됩니다)"
            }
          ]
        }
      ]
    },
    {
      "id": "ch01_d02",
      "title": "좌석 직접 고르기",
      "lines": [
        {
          "speaker": "나",
          "en": "Can I choose my seat?",
          "ko": "좌석을 직접 고를 수 있을까요?"
        },
        {
          "speaker": "직원",
          "en": "Of course. Window or aisle?",
          "ko": "그럼요. 창가요, 통로요?"
        },
        {
          "speaker": "나",
          "en": "An aisle seat, please.",
          "ko": "통로 좌석으로 부탁해요."
        },
        {
          "speaker": "직원",
          "en": "Done. You're in 14C.",
          "ko": "됐습니다. 14C 좌석이에요."
        }
      ],
      "keyExpressions": [
        {
          "en": "Can I choose my seat?",
          "ko": "좌석을 고를 수 있을까요? — 좌석을 직접 선택하고 싶을 때.",
          "alternatives": [
            {
              "en": "Can I pick my seat?",
              "ko": "좌석 골라도 되나요?"
            },
            {
              "en": "Is it possible to select a seat?",
              "ko": "좌석 선택이 가능한가요?"
            }
          ]
        },
        {
          "en": "window seat / aisle seat",
          "ko": "창가 좌석 / 통로 좌석. 가운데 좌석은 middle seat.",
          "alternatives": [
            {
              "en": "I'd prefer a window seat.",
              "ko": "창가 좌석이 좋아요."
            },
            {
              "en": "Do you have any aisle seats left?",
              "ko": "통로 좌석 남았나요?"
            }
          ]
        },
        {
          "en": "An aisle seat, please.",
          "ko": "통로 좌석으로요. — 끝에 please를 붙여 정중하게 요청.",
          "alternatives": [
            {
              "en": "I'll take the aisle.",
              "ko": "통로로 할게요."
            },
            {
              "en": "Aisle, if possible.",
              "ko": "가능하면 통로로요."
            }
          ]
        }
      ]
    },
    {
      "id": "ch01_d03",
      "title": "좌석 번호·가족 동석 확인",
      "lines": [
        {
          "speaker": "나",
          "en": "What's my seat number?",
          "ko": "제 좌석 번호가 뭔가요?"
        },
        {
          "speaker": "직원",
          "en": "You're in 14C, an aisle seat.",
          "ko": "14C, 통로 좌석입니다."
        },
        {
          "speaker": "나",
          "en": "Can my family sit together?",
          "ko": "가족이 같이 앉을 수 있을까요?"
        },
        {
          "speaker": "직원",
          "en": "Let me check... yes, rows 14 and 15.",
          "ko": "확인해볼게요... 네, 14열과 15열이에요."
        }
      ],
      "keyExpressions": [
        {
          "en": "What's my seat number?",
          "ko": "좌석 번호가 뭐예요? — 탑승 시각을 묻는 boarding time과 구분.",
          "alternatives": [
            {
              "en": "Which seat am I in?",
              "ko": "제 좌석이 어디인가요?"
            },
            {
              "en": "Can you tell me my seat?",
              "ko": "제 좌석 알려주시겠어요?"
            }
          ]
        },
        {
          "en": "sit together",
          "ko": "같이 앉다. — 일행이 함께 앉고 싶을 때.",
          "alternatives": [
            {
              "en": "sit next to each other",
              "ko": "서로 옆에 앉다"
            },
            {
              "en": "Can we get seats together?",
              "ko": "같이 앉는 좌석 가능할까요?"
            }
          ]
        },
        {
          "en": "Let me check.",
          "ko": "확인해볼게요. — 직원이 잠깐 알아볼 때 자주 쓰는 말.",
          "alternatives": [
            {
              "en": "Let me see.",
              "ko": "한번 볼게요."
            },
            {
              "en": "One moment, please.",
              "ko": "잠시만요."
            }
          ]
        }
      ]
    },
    {
      "id": "ch01_d04",
      "title": "항공편 정시·지연 확인",
      "lines": [
        {
          "speaker": "나",
          "en": "Is my flight on time?",
          "ko": "제 항공편 정시 출발인가요?"
        },
        {
          "speaker": "직원",
          "en": "Let me see... it's delayed by 30 minutes.",
          "ko": "잠시만요... 30분 지연입니다."
        },
        {
          "speaker": "나",
          "en": "Oh, what's the new departure time?",
          "ko": "아, 새 출발 시각은 언제죠?"
        },
        {
          "speaker": "직원",
          "en": "2:30 PM, from gate B12.",
          "ko": "오후 2시 30분, B12 게이트입니다."
        }
      ],
      "keyExpressions": [
        {
          "en": "Is my flight on time?",
          "ko": "정시 운항인가요? — on time은 '제시간에'.",
          "alternatives": [
            {
              "en": "Is the flight running on schedule?",
              "ko": "항공편 예정대로 운항하나요?"
            },
            {
              "en": "Are there any delays on my flight?",
              "ko": "제 항공편 지연 있나요?"
            }
          ]
        },
        {
          "en": "delayed (by 30 minutes)",
          "ko": "(30분) 지연된. — on time의 반대 상황.",
          "alternatives": [
            {
              "en": "It's running late.",
              "ko": "늦어지고 있어요."
            },
            {
              "en": "There's a 30-minute delay.",
              "ko": "30분 지연이 있어요."
            }
          ]
        },
        {
          "en": "departure time",
          "ko": "출발 시각. — 도착 시각은 arrival time.",
          "alternatives": [
            {
              "en": "When does it leave?",
              "ko": "언제 출발해요?"
            },
            {
              "en": "the new departure time",
              "ko": "새 출발 시각"
            }
          ]
        }
      ]
    },
    {
      "id": "ch01_d05",
      "title": "모바일 탑승권 받기",
      "lines": [
        {
          "speaker": "나",
          "en": "Where can I get my boarding pass?",
          "ko": "탑승권은 어디서 받나요?"
        },
        {
          "speaker": "직원",
          "en": "You can download it in the app.",
          "ko": "앱에서 다운로드하시면 됩니다."
        },
        {
          "speaker": "나",
          "en": "Can I use the mobile one at the gate?",
          "ko": "게이트에서 모바일로 써도 되나요?"
        },
        {
          "speaker": "직원",
          "en": "Yes, just show the QR code.",
          "ko": "네, QR 코드만 보여주시면 돼요."
        }
      ],
      "keyExpressions": [
        {
          "en": "boarding pass",
          "ko": "탑승권. — 체크인을 마치면 받습니다.",
          "alternatives": [
            {
              "en": "Where do I pick up my boarding pass?",
              "ko": "탑승권 어디서 받나요?"
            },
            {
              "en": "I need to print my boarding pass.",
              "ko": "탑승권을 출력해야 해요."
            }
          ]
        },
        {
          "en": "mobile boarding pass",
          "ko": "모바일 탑승권. — 앱·지갑에 저장하는 전자 탑승권.",
          "alternatives": [
            {
              "en": "digital boarding pass",
              "ko": "전자 탑승권"
            },
            {
              "en": "boarding pass on my phone",
              "ko": "휴대폰 속 탑승권"
            }
          ]
        },
        {
          "en": "show the QR code",
          "ko": "QR 코드를 보여주다. — 게이트·보안검색에서.",
          "alternatives": [
            {
              "en": "scan the QR code",
              "ko": "QR 코드를 스캔하다"
            },
            {
              "en": "Just show this at the gate.",
              "ko": "게이트에서 이것만 보여주세요."
            }
          ]
        }
      ]
    },
    {
      "id": "ch01_d06",
      "title": "수하물 허용량 묻기",
      "lines": [
        {
          "speaker": "나",
          "en": "What's the baggage allowance?",
          "ko": "수하물 허용량이 어떻게 되나요?"
        },
        {
          "speaker": "직원",
          "en": "One checked bag, up to 23 kilos.",
          "ko": "위탁 수하물 1개, 23킬로까지요."
        },
        {
          "speaker": "나",
          "en": "And a carry-on?",
          "ko": "기내 반입 가방도 되나요?"
        },
        {
          "speaker": "직원",
          "en": "Yes, one carry-on and one small bag.",
          "ko": "네, 기내 가방 1개와 작은 가방 1개요."
        }
      ],
      "keyExpressions": [
        {
          "en": "baggage allowance",
          "ko": "수하물 허용량. — 무료로 가져갈 수 있는 한도.",
          "alternatives": [
            {
              "en": "luggage allowance",
              "ko": "수하물 허용량 (같은 뜻)"
            },
            {
              "en": "How much baggage can I bring?",
              "ko": "수하물 얼마나 가져갈 수 있나요?"
            }
          ]
        },
        {
          "en": "checked bag / carry-on",
          "ko": "위탁 수하물 / 기내 반입 가방.",
          "alternatives": [
            {
              "en": "checked luggage",
              "ko": "위탁 수하물"
            },
            {
              "en": "hand luggage / cabin bag",
              "ko": "기내 가방"
            }
          ]
        },
        {
          "en": "up to 23 kilos",
          "ko": "23킬로까지. — up to는 '~까지(최대)'.",
          "alternatives": [
            {
              "en": "a maximum of 23 kilos",
              "ko": "최대 23킬로"
            },
            {
              "en": "no more than 23 kilos",
              "ko": "23킬로 이하"
            }
          ]
        }
      ]
    },
    {
      "id": "ch01_d07",
      "title": "위탁 수하물 추가 구매",
      "lines": [
        {
          "speaker": "나",
          "en": "Can I add an extra checked bag?",
          "ko": "위탁 수하물을 하나 추가할 수 있나요?"
        },
        {
          "speaker": "직원",
          "en": "Sure, it's 40 euros online.",
          "ko": "네, 온라인으로 40유로입니다."
        },
        {
          "speaker": "나",
          "en": "Is it cheaper to pay now?",
          "ko": "지금 결제하면 더 싼가요?"
        },
        {
          "speaker": "직원",
          "en": "Yes, it costs more at the airport.",
          "ko": "네, 공항에서는 더 비싸요."
        }
      ],
      "keyExpressions": [
        {
          "en": "add an extra bag",
          "ko": "가방을 하나 추가하다. — extra는 '추가의'.",
          "alternatives": [
            {
              "en": "buy extra baggage",
              "ko": "추가 수하물을 사다"
            },
            {
              "en": "add another checked bag",
              "ko": "위탁 수하물을 하나 더 추가하다"
            }
          ]
        },
        {
          "en": "It's 40 euros.",
          "ko": "40유로입니다. — 요금을 안내하는 표현.",
          "alternatives": [
            {
              "en": "That'll be 40 euros.",
              "ko": "40유로 되겠습니다."
            },
            {
              "en": "It costs 40 euros.",
              "ko": "40유로입니다."
            }
          ]
        },
        {
          "en": "It costs more at the airport.",
          "ko": "공항에서는 더 비쌉니다. — 미리 사면 저렴하다는 뜻.",
          "alternatives": [
            {
              "en": "It's more expensive at the airport.",
              "ko": "공항에서는 더 비싸요."
            },
            {
              "en": "You'll pay extra at the airport.",
              "ko": "공항에서는 추가로 내셔야 해요."
            }
          ]
        }
      ]
    },
